{{!
    @template mod_reflect/report

    Teacher report view for a reflect activity.

    Example context (json):
    {
        "hasdata": true,
        "questions": [
            { "id": 1, "title": "How confident are you?", "isnumeric": true },
            { "id": 2, "title": "What did you learn?", "isnumeric": false }
        ],
        "users": [
            {
                "fullname": "John Doe",
                "picture": "<img...>",
                "responses": [
                    { "hasresponse": true, "value": "85", "text": "-" },
                    { "hasresponse": true, "value": "-", "text": "I learned a lot." }
                ],
                "hasglobalcomment": true,
                "globalcomment": "Great activity."
            }
        ]
    }
}}
<div class="mod-reflect-report mt-4">
    {{#hasdata}}
        <div class="table-responsive">
            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th scope="col" class="mod-reflect-user-col">{{str_user}}</th>
                        {{#questions}}
                            <th scope="col" class="text-center">{{title}}</th>
                        {{/questions}}
                        <th scope="col">{{str_comment}}</th>
                    </tr>
                </thead>
                <tbody>
                    {{#users}}
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    {{{picture}}}
                                    <span>{{fullname}}</span>
                                </div>
                            </td>
                            {{#responses}}
                                <td class="text-center">
                                    {{#hasresponse}}
                                        {{#value}}
                                            {{#isnumeric}}<span class="badge bg-secondary">{{value}}</span>{{/isnumeric}}
                                            {{^isnumeric}}{{{value}}}{{/isnumeric}}
                                        {{/value}}
                                        {{#text}}
                                            {{^isnumeric}}<div class="small text-start">{{{text}}}</div>{{/isnumeric}}
                                        {{/text}}
                                    {{/hasresponse}}
                                    {{^hasresponse}}
                                        <span class="text-muted">-</span>
                                    {{/hasresponse}}
                                </td>
                            {{/responses}}
                            <td>
                                {{#hasglobalcomment}}
                                    <div class="small text-start">{{{globalcomment}}}</div>
                                {{/hasglobalcomment}}
                            </td>
                        </tr>
                    {{/users}}
                </tbody>
            </table>
        </div>
    {{/hasdata}}

    {{^hasdata}}
        <div class="alert alert-info">
            {{str_nodatafound}}
        </div>
    {{/hasdata}}
</div>
