{{!
    @template mod_reflect/view_student

    Student view for responding to a reflect activity.

    Classes required for JS: none.
    Data attributes required for JS: none.
    Context variables required for this template:
        * cmid - Course module ID.
        * instanceid - Reflect instance ID.
        * intro - The activity description.
        * questions - Array of question objects.
        * allowcomment - Boolean whether comments are allowed globally.
        * hasquestions - Boolean if there are questions to display.
        * str_noquestions - String for no questions.
        * str_comment - String for comment label.

    Example context (json):
    {
        "cmid": 42,
        "instanceid": 7,
        "intro": "<p>Reflect on your learning today.</p>",
        "questions": [
            {
                "id": 1,
                "question": "<p>How confident are you?</p>",
                "isnumeric": true,
                "istext": false
            }
        ],
        "allowcomment": true,
        "hasquestions": true,
        "str_noquestions": "No questions have been configured yet.",
        "str_comment": "Add a comment (optional)"
    }
}}
<div id="mod-reflect-student" class="mod-reflect-container" data-cmid="{{cmid}}" data-instanceid="{{instanceid}}" data-saving="{{#str}}saving, mod_reflect{{/str}}" data-saved="{{#str}}saved, mod_reflect{{/str}}">

    {{#intro}}
    <div class="mod-reflect-header card mb-4">
        <div class="card-body">
            <div class="mod-reflect-intro">{{{intro}}}</div>
        </div>
    </div>
    {{/intro}}

    {{#hasquestions}}
        <div class="mod-reflect-questions-list">
            {{#questions}}
                <div class="mod-reflect-question-card card mb-4" data-questionid="{{id}}">
                    <div class="card-body">
                        <div class="mod-reflect-question-text mb-4">{{{question}}}</div>

                        {{#isnumeric}}
                            <div class="mod-reflect-response-numeric mt-3">
                                <div class="d-flex justify-content-between align-items-center mb-2 text-muted small">
                                    <span>0</span>
                                    <span class="mod-reflect-slider-value badge bg-primary">{{#value}}{{value}}{{/value}}{{^value}}0{{/value}}</span>
                                    <span>100</span>
                                </div>
                                <input type="range" class="form-range mod-reflect-slider" 
                                       id="reflect-slider-{{id}}" data-questionid="{{id}}" 
                                       min="0" max="100" step="1" value="{{#value}}{{value}}{{/value}}{{^value}}0{{/value}}">
                            </div>
                        {{/isnumeric}}

                        {{#istext}}
                            <div class="mod-reflect-response-text mt-3">
                                <textarea class="form-control mod-reflect-textarea" 
                                          id="reflect-text-{{id}}" data-questionid="{{id}}" 
                                          rows="4" placeholder="Sua resposta...">{{text}}</textarea>
                            </div>
                        {{/istext}}

                        <div class="mod-reflect-save-status text-muted small mt-2 d-none">
                            <i class="fa fa-circle-o-notch fa-spin" aria-hidden="true"></i> <span class="status-text">{{#str}}saving, mod_reflect{{/str}}</span>
                        </div>
                    </div>
                </div>
            {{/questions}}

            {{#allowcomment}}
                <div class="mod-reflect-comment-card card mb-4">
                    <div class="card-body">
                        <label for="reflect-global-comment" class="form-label">{{str_comment}}</label>
                        <textarea class="form-control mod-reflect-global-comment" 
                                  id="reflect-global-comment" rows="3">{{globalcomment}}</textarea>
                        <div class="mod-reflect-save-status text-muted small mt-2 d-none">
                            <i class="fa fa-circle-o-notch fa-spin" aria-hidden="true"></i> <span class="status-text">{{#str}}saving, mod_reflect{{/str}}</span>
                        </div>
                    </div>
                </div>
            {{/allowcomment}}

            <div class="mod-reflect-submit-container mt-4 mb-4 text-end">
                <form method="post" action="view.php">
                    <input type="hidden" name="id" value="{{cmid}}">
                    <input type="hidden" name="action" value="submit">
                    <input type="hidden" name="sesskey" value="{{sesskey}}">
                    <button type="submit" class="btn btn-primary mod-reflect-submit-btn">
                        {{str_submit}}
                    </button>
                </form>
            </div>
        </div>
    {{/hasquestions}}

    {{^hasquestions}}
        <div class="alert alert-info">
            {{str_noquestions}}
        </div>
    {{/hasquestions}}

</div>
